// firestore.rules
// Deploy these in Firebase Console → Firestore → Rules
// OR via: firebase deploy --only firestore:rules

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /orders/{orderId} {
      // Anyone can READ orders (shop floor view)
      allow read: if true;

      // Only authenticated managers can CREATE or DELETE
      allow create, delete: if request.auth != null;

      // Anyone can UPDATE (to advance stage) — but only the status and timestamp fields
      // Managers can update anything
      allow update: if request.auth != null
        || (request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['status', 'curingAt', 'paintAt', 'shippingAt']));
    }
  }
}
